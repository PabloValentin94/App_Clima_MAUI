<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App_Clima_MAUI.MainPage">
    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,*" Padding="10">
		<!-- Utilização de Ícone (Font Awesome) -->
		<Button x:Name="btn_current_locality" Grid.Column="0" Grid.Row="0" Text="&#xf3c5;" FontFamily="FontAwesomeFreeSolid900" Clicked="btn_current_locality_Clicked"/>

		<Entry x:Name="txt_city" Grid.Column="1" Grid.Row="0" Placeholder="Digite uma cidade..." Keyboard="Text" />
        
        <!-- Utilização de Ícone (Font Awesome) -->
        <Button x:Name="btn_search" Grid.Column="2" Grid.Row="0" Text="&#xf002;" FontFamily="FontAwesomeFreeSolid900" Clicked="btn_search_Clicked"/>

        <WebView x:Name="wbview_localization" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3"/>
    </Grid>
</ContentPage>
